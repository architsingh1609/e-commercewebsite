package ECommerceWebsite;

import java.time.Duration;

import org.junit.jupiter.api.AfterEach;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.openqa.selenium.By;
import org.openqa.selenium.JavascriptExecutor;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.WebElement;
import org.openqa.selenium.chrome.ChromeDriver;
import org.openqa.selenium.support.ui.ExpectedConditions;
import org.openqa.selenium.support.ui.WebDriverWait;

public class placeorder {

    WebDriver driver;
    WebDriverWait wait;

    @BeforeEach
    public void setup() {

        driver = new ChromeDriver();
        driver.manage().window().maximize();
        driver.manage().timeouts().implicitlyWait(Duration.ofSeconds(10));

        wait = new WebDriverWait(driver, Duration.ofSeconds(15));
    }

    @Test
    public void logoutinfo() {

        driver.get("https://automationexercise.com/login");

        // LOGIN
        driver.findElement(By.name("email"))
                .sendKeys("architsingh1609@gmail.com");

        driver.findElement(By.name("password"))
                .sendKeys("Ar@160904");

        driver.findElement(By.xpath("//button[normalize-space()='Login']"))
                .click();

        // VIEW PRODUCT (FIX FOR AD IFRAME ISSUE)
        WebElement viewProduct = wait.until(
                ExpectedConditions.elementToBeClickable(
                        By.linkText("View Product")));

        JavascriptExecutor js = (JavascriptExecutor) driver;
        js.executeScript("arguments[0].scrollIntoView(true);", viewProduct);

        wait.until(ExpectedConditions.visibilityOf(viewProduct));
        viewProduct.click();

        // QUANTITY
        WebElement qty = wait.until(
                ExpectedConditions.visibilityOfElementLocated(
                        By.id("quantity")));

        System.out.println("Quantity: " +
                qty.getAttribute("value"));

        // ADD TO CART
        driver.findElement(
                By.xpath("//button[normalize-space()='Add to cart']"))
                .click();

        // VIEW CART
        wait.until(ExpectedConditions.elementToBeClickable(
                By.xpath("//u[normalize-space()='View Cart']")))
                .click();

        // PRICE DETAILS
        WebElement totalprice = wait.until(
                ExpectedConditions.visibilityOfElementLocated(
                        By.xpath("//p[@class='cart_total_price']")));

        System.out.println("Total Price: " +
                totalprice.getText());

        // CHECKOUT
        driver.findElement(
                By.xpath("//a[normalize-space()='Proceed To Checkout']"))
                .click();

        // PLACE ORDER
        wait.until(ExpectedConditions.elementToBeClickable(
                By.linkText("Place Order")))
                .click();

        // PAYMENT DETAILS
        driver.findElement(By.name("name_on_card"))
                .sendKeys("archit");

        driver.findElement(By.name("card_number"))
                .sendKeys("12345");

        driver.findElement(By.name("cvc"))
                .sendKeys("123");

        driver.findElement(By.name("expiry_month"))
                .sendKeys("09");

        driver.findElement(By.name("expiry_year"))
                .sendKeys("2026");

        driver.findElement(By.id("submit"))
                .click();

        System.out.println("Order Placed Successfully");
    }

    @AfterEach
    public void close() {
        driver.quit();
    }
}
