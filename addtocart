package ECommerceWebsite;

import java.time.Duration;

import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.openqa.selenium.By;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.WebElement;
import org.openqa.selenium.chrome.ChromeDriver;
import org.openqa.selenium.interactions.Actions;

public class addtocart {
	WebDriver driver;

	@BeforeEach
    public void logout() {
        driver = new ChromeDriver();
        driver.manage().timeouts().implicitlyWait(Duration.ofSeconds(10));
        driver.manage().window().maximize();
    }

    @Test
    public void logoutinfo() throws InterruptedException {
    	driver.get("https://automationexercise.com/login");
    	driver.findElement(By.xpath("//a[@href='/products']")).click();
    	Thread.sleep(4000);
    	WebElement over = driver.findElement(By.xpath("(//div[@class='productinfo text-center'])[1]"));
    	WebElement to = driver.findElement(By.className("add-to-cart"));
    	Actions act = new Actions(driver);
    	act.moveToElement(over).moveToElement(to).click().perform();
}
}
